    style SY1 fill:#4a90d9,color:white
    style SX2 fill:#4a90d9,color:white
    style SY2 fill:#4a90d9,color:white
    style SX3 fill:#4a90d9,color:white
    style SY3 fill:#4a90d9,color:white
    style AT fill:#e8a838,color:white
    style TF fill:#7bb563,color:white
